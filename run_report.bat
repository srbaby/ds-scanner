@echo off
chcp 65001 >nul
cls
title 💰 我的投资周报 - 启动中...

:: ============================================================
:: 1. 定义 ESC 变量 (这是实现毫秒级变色的关键魔法)
:: ============================================================
for /F "tokens=1,2 delims=#" %%a in ('"prompt #$H#$E# & echo on & for %%b in (1) do rem"') do set "ESC=%%b"

:: ============================================================
:: 2. 打印标题 (使用 %ESC%[92m 变成亮绿色)
:: ============================================================
echo %ESC%[92m==================================================%ESC%[0m
echo %ESC%[92m🚀 正在唤醒 Python uv 环境...%ESC%[0m
echo %ESC%[92m==================================================%ESC%[0m
echo.

:: ============================================================
:: 3. 运行 Python (正文保持默认白色)
:: ============================================================
:: cd /d "D:\Users\JanY\你的项目目录"

uv run automation/ds_scanner.py

echo.
echo %ESC%[92m✅ 报表生成完毕，请检阅！%ESC%[0m
echo.

pause